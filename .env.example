# HealthBot Environment Variables

# WhatsApp (Meta Business API / Twilio)
WHATSAPP_VERIFY_TOKEN=healthbot_verify_token_change_this
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# SMS Gateway (Twilio / other)
SMS_ACCOUNT_SID=your_sms_account_sid_here
SMS_AUTH_TOKEN=your_sms_auth_token_here
SMS_FROM_NUMBER=+1234567890

# Ollama (text + vision for prescription/report review)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_VISION_MODEL=llava

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# Auth (change in production)
AUTH_SECRET=change_this_secret_in_production
ADMIN_EMAIL=admin@healthbot.local
ADMIN_PASSWORD=admin123
